<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<BorderPane fx:id="rootPane"
            prefWidth="960" prefHeight="640"
            style="-fx-background-color: linear-gradient(from 0% 0% to 100% 100%, #162535 0%, #0c1420 100%);"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="Luxora.Luxora.StartController">

    <!-- TOP NAV -->
    <top>
        <HBox alignment="CENTER_RIGHT" style="-fx-padding: 18 36;">
            <Button text="Staff Member"
                    style="-fx-background-color: rgba(255,255,255,0.07);
                           -fx-text-fill: white; -fx-font-size: 12;
                           -fx-cursor: hand;
                           -fx-border-color: rgba(255,255,255,0.18);
                           -fx-border-radius: 20; -fx-background-radius: 20;
                           -fx-padding: 6 18;"
                    onAction="#goToAdmin"/>
        </HBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="36">

            <!-- Brand -->
            <VBox alignment="CENTER" spacing="8">
                <Label text="LUXORA"
                       style="-fx-text-fill: white; -fx-font-size: 36;
                              -fx-font-weight: bold; -fx-font-family: Georgia;"/>
                <Label text="Premium E-Commerce Platform"
                       style="-fx-text-fill: #94a3b8; -fx-font-size: 14;"/>
            </VBox>

            <!-- Portal Cards -->
            <HBox alignment="CENTER" spacing="36">

                <!-- Customer Card -->
                <VBox fx:id="customerCard" alignment="CENTER" spacing="16"
                      prefWidth="310" prefHeight="280"
                      style="-fx-background-color: white; -fx-background-radius: 12;
                             -fx-cursor: hand; -fx-padding: 36 28;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 24, 0, 0, 8);"
                      onMouseClicked="#customerLogin"
                      onMouseEntered="#onCustomerHover"
                      onMouseExited="#onCustomerExit">

                    <Label text="C"
                           style="-fx-background-color: #0f172a;
                                  -fx-background-radius: 100;
                                  -fx-min-width: 62; -fx-min-height: 62;
                                  -fx-max-width: 62; -fx-max-height: 62;
                                  -fx-alignment: center; -fx-font-size: 26;
                                  -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label text="Customer Portal"
                           style="-fx-font-size: 18; -fx-font-weight: bold;
                                  -fx-text-fill: #1e293b;"/>
                    <Label text="Browse products and manage your orders"
                           style="-fx-font-size: 13; -fx-text-fill: #94a3b8;"
                           wrapText="true" maxWidth="220"
                           alignment="CENTER" textAlignment="CENTER"/>
                    <Button fx:id="customerEnterBtn" text="Enter  →"
                            prefHeight="38" maxWidth="Infinity"
                            onMouseClicked="#customerLogin"
                            style="-fx-background-color: #0f172a;
                                   -fx-text-fill: white; -fx-font-size: 13;
                                   -fx-font-weight: bold; -fx-background-radius: 7;
                                   -fx-cursor: hand;"/>
                </VBox>

                <!-- Manager Card -->
                <VBox fx:id="managerCard" alignment="CENTER" spacing="16"
                      prefWidth="310" prefHeight="280"
                      style="-fx-background-color: white; -fx-background-radius: 12;
                             -fx-cursor: hand; -fx-padding: 36 28;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 24, 0, 0, 8);"
                      onMouseClicked="#managerLogin"
                      onMouseEntered="#onManagerHover"
                      onMouseExited="#onManagerExit">

                    <Label text="M"
                           style="-fx-background-color: #0f172a;
                                  -fx-background-radius: 100;
                                  -fx-min-width: 62; -fx-min-height: 62;
                                  -fx-max-width: 62; -fx-max-height: 62;
                                  -fx-alignment: center; -fx-font-size: 26;
                                  -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label text="Manager Portal"
                           style="-fx-font-size: 18; -fx-font-weight: bold;
                                  -fx-text-fill: #1e293b;"/>
                    <Label text="Manage inventory and product listings"
                           style="-fx-font-size: 13; -fx-text-fill: #94a3b8;"
                           wrapText="true" maxWidth="220"
                           alignment="CENTER" textAlignment="CENTER"/>
                    <Button fx:id="managerEnterBtn" text="Enter  →"
                            prefHeight="38" maxWidth="Infinity"
                            onMouseClicked="#managerLogin"
                            style="-fx-background-color: #0f172a;
                                   -fx-text-fill: white; -fx-font-size: 13;
                                   -fx-font-weight: bold; -fx-background-radius: 7;
                                   -fx-cursor: hand;"/>
                </VBox>

            </HBox>
        </VBox>
    </center>

    <bottom>
        <HBox prefHeight="44" alignment="CENTER">
            <Label text="&#169; 2026 Luxora. All rights reserved."
                   style="-fx-text-fill: #64748b; -fx-font-size: 12;"/>
        </HBox>
    </bottom>

</BorderPane>
